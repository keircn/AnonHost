# NextAuth Configuration - https://next-auth.js.org/configuration/options
NEXTAUTH_SECRET="your-secret-here"   # Secret used to encrypt session data
NEXTAUTH_URL="http://localhost:3000" # Production/Development URL of your application

# Discord OAuth Credentials - https://discord.com/developers/applications
DISCORD_CLIENT_ID=""     # Discord application client ID
DISCORD_CLIENT_SECRET="" # Discord application client secret

# For local development outside Docker:
DATABASE_URL="postgresql://anonhost:change-me@localhost:5432/anonhost"

# Postgres defaults (used by docker)
POSTGRES_DB="anonhost"
POSTGRES_USER="anonhost"
POSTGRES_PASSWORD="change-me"

# Docker app bind options (for reverse proxy)
ANONHOST_BIND_IP="127.0.0.1"
ANONHOST_PORT="1984"

# Cloudflare R2 - https://developers.cloudflare.com/r2/
R2_ACCOUNT_ID=""        # Cloudflare account ID
R2_ACCESS_KEY_ID=""     # R2 access key ID
R2_SECRET_ACCESS_KEY="" # R2 secret access key
R2_BUCKET_NAME=""       # R2 bucket name
R2_PUBLIC_URL=""        # Public URL for R2 bucket access

# SMTP Configuration
SMTP_HOST=""              # SMTP server host (for example smtp.resend.com)
SMTP_PORT="587"           # SMTP server port (usually 587 or 465)
SMTP_SECURE="false"       # true for implicit TLS (usually port 465)
SMTP_USER=""              # SMTP username (optional for local relay)
SMTP_PASS=""              # SMTP password (optional for local relay)
SMTP_FROM_EMAIL=""        # Sender email address
SMTP_FROM_NAME="AnonHost" # Sender display name (optional)
